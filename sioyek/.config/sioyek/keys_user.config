# nvim-aligned keybindings for sioyek — extends/overrides /etc/sioyek/keys.config.
# Sioyek already matches nvim for: gg / G (top/bottom), / (search), n / N (next/prev
# result), t (toc). Below are the bindings nvim trains your fingers for that sioyek
# does NOT bind by default. Multiple keys can map to one command (additive).

# --- Half-page scroll: nvim <C-d> / <C-u> ---
# (move_screen_ratio in prefs controls the distance; default 0.5 = half a screen)
screen_down	<C-d>
screen_up	<C-u>

# --- Next / previous search result: your nvim remap of <C-n> / <C-p> ---
next_item	<C-n>
previous_item	<C-p>

# --- Jumplist navigation: nvim <C-o> back / <C-i> forward ---
# Overrides sioyek's default <C-o> = open_document_embedded; use `o` / `<C-S-o>` for that.
prev_state	<C-o>
next_state	<C-i>

# --- Page flipping: J / K (mirrors your <leader>j / <leader>k paragraph jumps) ---
next_page	J
previous_page	K
