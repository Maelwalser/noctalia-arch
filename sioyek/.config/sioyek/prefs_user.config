# User preferences for sioyek — overrides /etc/sioyek/prefs.config.
# Only list the keys you want to change; everything else falls back to defaults.
# Docs: https://sioyek-documentation.readthedocs.io/

# --- Dark mode by default ---
# Run toggle_dark_mode at startup (the modern way; `default_dark_mode` is deprecated).
startup_commands	toggle_dark_mode

# Soften harsh whites on the black background (0 = max dim, 1 = full white).
dark_mode_contrast	0.8

# Tune the dark background away from pure black if you prefer (RGB 0..1).
dark_mode_background_color	0.05 0.05 0.05

# --- Quality of life ---
# Zoom toward the cursor instead of the screen center.
wheel_zoom_on_cursor	1

# Don't nag about updates on a rolling distro (handled by pacman).
check_for_updates_on_startup	0

# Reuse one window instead of spawning a new instance per file.
should_launch_new_window	0
should_launch_new_instance	0
